@model Project2EmailNight.Dtos.ConfirmMailDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Email Doğrulama</title>
    <link rel="icon" href="~/vertical/assets/images/favicon-32x32.png" type="image/png" />
    <link rel="stylesheet" href="~/vertical/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Roboto&display=swap" />
    <link rel="stylesheet" href="~/vertical/assets/css/icons.css" />
    <link rel="stylesheet" href="~/vertical/assets/css/app.css" />
</head>
<body>
    <div class="wrapper">
        <div class="authentication-reset-password d-flex align-items-center justify-content-center">
            <div class="row">
                <div class="col-12 col-lg-10 mx-auto">
                    <div class="card radius-15">
                        <div class="row g-0">
                            <div class="col-lg-5">
                                <div class="card-body p-md-5">
                                    <div class="text-left">
                                        <img src="~/vertical/assets/images/logo-img.png" width="180" alt="">
                                    </div>
                                    <h4 class="mt-5 font-weight-bold">Email Doğrulama</h4>
                                    <p class="text-muted">Lütfen email adresinize gönderilen 6 haneli doğrulama kodunu giriniz.</p>

                                    <form method="post" asp-controller="ConfirmMail" asp-action="Index">
                                        <div class="mb-3 mt-5">
                                            <label asp-for="Mail" class="form-label">Email Adresi</label>
                                            <input type="text" asp-for="Mail" class="form-control" value="@ViewBag.v" readonly />
                                        </div>
                                        <div class="mb-3">
                                            <label asp-for="ConfirmCode" class="form-label">Doğrulama Kodu</label>
                                            <input type="text" asp-for="ConfirmCode" class="form-control" placeholder="6 haneli kodu girin" />
                                        </div>

                                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                                        <div class="d-grid gap-2">
                                            <button type="submit" class="btn btn-primary">Doğrula ve Tamamla</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <div class="col-lg-7">
                                <img src="~/vertical/assets/images/login-images/forgot-password-frent-img.jpg" class="card-img login-img h-100" alt="...">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>