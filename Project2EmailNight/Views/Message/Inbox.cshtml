@model List<Project2EmailNight.Entities.Message>
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>MailApp</title>
    <link rel="icon" href="~/vertical/assets/images/favicon-32x32.png" type="image/png" />
    <link href="~/vertical/assets/plugins/simplebar/css/simplebar.css" rel="stylesheet" />
    <link href="~/vertical/assets/plugins/perfect-scrollbar/css/perfect-scrollbar.css" rel="stylesheet" />
    <link href="~/vertical/assets/plugins/metismenu/css/metisMenu.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/vertical/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Roboto&display=swap" />
    <link rel="stylesheet" href="~/vertical/assets/css/icons.css" />
    <link rel="stylesheet" href="~/vertical/assets/css/app.css" />
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">

    <style>
        .sidebar-wrapper {
            display: none !important;
        }

        .top-header {
            left: 0 !important;
            width: 100% !important;
            border-bottom: 1px solid #e4e4e4;
        }

        body {
            background-color: #f4f6f9 !important;
        }

        .page-wrapper {
            margin-left: 0 !important;
            margin-top: 60px !important;
            padding: 20px !important;
        }

        .page-content-wrapper, .page-content {
            padding: 0 !important;
            margin: 0 !important;
        }

        .email-wrapper {
            height: calc(100vh - 100px) !important;
            width: 100% !important;
            margin: 0 !important;
            border: 1px solid #e4e4e4 !important;
            border-radius: 10px !important;
            box-shadow: 0 4px 10px rgba(0,0,0,0.03) !important;
            background-color: #ffffff !important;
            overflow: hidden;
        }

        .email-sidebar {
            border-right: 1px solid #e4e4e4 !important;
            background: #fff !important;
            height: 100% !important;
            overflow-y: auto !important;
        }

        .email-navigation {
            height: auto !important;
        }

        .email-header {
            border-bottom: 1px solid #e4e4e4 !important;
            background: #fff !important;
            height: 60px !important;
        }

        .email-content {
            background: #fff !important;
        }

        .btn-primary {
            background-color: #673ab7 !important;
            border-color: #673ab7 !important;
        }

            .btn-primary:hover {
                background-color: #552fa8 !important;
                border-color: #552fa8 !important;
            }

        .text-primary {
            color: #673ab7 !important;
        }

        .bg-primary {
            background-color: #673ab7 !important;
        }

        .list-group-item.active {
            background-color: #f3e5f5 !important;
            color: #673ab7 !important;
            border-left: 4px solid #673ab7 !important;
            border-color: transparent !important;
        }

        .email-navigation .list-group-item {
            padding: 10px 20px !important;
        }
    </style>
</head>

<body>
    <div class="wrapper">

        <header class="top-header">
            <nav class="navbar navbar-expand">
                <div class="left-topbar d-flex align-items-center">
                    <img src="~/vertical/assets/images/logo-icon.png" width="30" alt="" class="ms-3" />
                    <h4 class="logo-text ms-2 mb-0 text-dark">MailApp</h4>
                </div>

                <div class="flex-grow-1 search-bar">
                    <form method="get" action="/Message/Search" class="input-group">
                        <button class="btn btn-search-back search-arrow-back" type="button"><i class="bx bx-arrow-back"></i></button>
                        <input type="text" name="query" class="form-control" placeholder="Mail Kutusunda Ara..." value="@Context.Request.Query["query"]" />
                        <button class="btn btn-light text-dark" style="border:none; background:transparent;" type="submit"><i class="lni lni-search-alt"></i></button>
                    </form>
                </div>

                <div class="right-topbar ms-auto">
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown dropdown-lg">
                            <a class="nav-link dropdown-toggle dropdown-toggle-nocaret position-relative" href="javascript:;" data-bs-toggle="dropdown">
                                <i class="bx bx-comment-detail vertical-align-middle text-dark"></i>
                                @if (ViewBag.InboxCount > 0)
                                {
                                    <span class="msg-count" style="background-color: #673ab7;">@ViewBag.InboxCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item dropdown dropdown-lg">
                            <a class="nav-link dropdown-toggle dropdown-toggle-nocaret position-relative" href="javascript:;" data-bs-toggle="dropdown">
                                <i class="bx bx-bell vertical-align-middle text-dark"></i>
                            </a>
                        </li>
                        <li class="nav-item dropdown dropdown-user-profile">
                            <a class="nav-link dropdown-toggle dropdown-toggle-nocaret" href="javascript:;" data-bs-toggle="dropdown">
                                <div class="d-flex user-box align-items-center">
                                    <div class="user-info text-end me-2">
                                        <p class="user-name mb-0 text-dark font-weight-bold">@ViewBag.CurrentUser.Name @ViewBag.CurrentUser.SurName</p>
                                        <p class="designattion mb-0 text-muted">Çevrimiçi</p>
                                    </div>
                                    <img src="@(!string.IsNullOrEmpty(ViewBag.CurrentUser.ImageUrl) ? "/images/" + ViewBag.CurrentUser.ImageUrl : "/vertical/assets/images/avatars/avatar-1.png")" class="user-img" alt="user avatar">
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" href="/Profile/Index"><i class="bx bx-user"></i><span>Profilim</span></a>
                                <div class="dropdown-divider mb-0"></div>
                                <a class="dropdown-item" href="/Login/UserLogin"><i class="bx bx-power-off"></i><span>Çıkış Yap</span></a>
                            </div>
                        </li>
                        <li class="nav-item dropdown dropdown-language">
                            <a class="nav-link dropdown-toggle dropdown-toggle-nocaret" href="javascript:;" data-bs-toggle="dropdown">
                                <div class="lang d-flex">
                                    <div><i class="flag-icon flag-icon-us"></i></div>
                                    <div><span class="text-dark">En</span></div>
                                </div>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <div class="page-wrapper">
            <div class="page-content-wrapper">
                <div class="page-content">
                    <div class="email-wrapper">

                        <div class="email-sidebar">
                            <div class="email-sidebar-header d-grid">
                                <a href="javascript:;" class="btn btn-primary compose-mail-btn"><i class='bx bx-plus me-2'></i> Yeni Mesaj</a>
                            </div>
                            <div class="email-sidebar-content">
                                <div class="email-navigation">
                                    <div class="list-group list-group-flush">
                                        <a href="/Message/Inbox" class="list-group-item @(ViewBag.ActiveFolder == "Inbox" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-inbox me-3 font-20'></i><span>Gelen Kutusu</span> @if(ViewBag.InboxCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.InboxCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Starred" class="list-group-item @(ViewBag.ActiveFolder == "Starred" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-star me-3 font-20 text-warning'></i><span>Yıldızlılar</span> @if(ViewBag.StarredCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.StarredCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/SendBox" class="list-group-item @(ViewBag.ActiveFolder == "SendBox" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-send me-3 font-20 text-info'></i><span>Gönderilenler</span> @if(ViewBag.SendBoxCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.SendBoxCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Drafts" class="list-group-item @(ViewBag.ActiveFolder == "Drafts" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-file-blank me-3 font-20 text-secondary'></i><span>Taslaklar</span> @if(ViewBag.DraftsCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.DraftsCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Spam" class="list-group-item @(ViewBag.ActiveFolder == "Spam" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-info-circle me-3 font-20 text-danger'></i><span>Spam</span> @if(ViewBag.SpamCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.SpamCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Trash" class="list-group-item @(ViewBag.ActiveFolder == "Trash" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-trash-alt me-3 font-20 text-secondary'></i><span>Çöp Kutusu</span> @if(ViewBag.TrashCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.TrashCount</span>
                                                                                        }
                                        </a>
                                    </div>
                                    <div class="list-group list-group-flush mt-1">
                                        <div class="list-group-item text-muted" style="background: transparent; border: none; font-size: 11px; font-weight: bold; letter-spacing: 1px;"><i class="bx bx-folder me-1"></i> KATEGORİLER</div>
                                        <a href="/Message/Category/İş" class="list-group-item @(ViewBag.ActiveFolder == "İş" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-circle me-3 font-14' style="color: #673ab7;"></i><span>İş</span> @if(ViewBag.IsCount > 0){
                                            <span class="badge bg-primary rounded-pill ms-auto">@ViewBag.IsCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Category/Aile" class="list-group-item @(ViewBag.ActiveFolder == "Aile" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-circle me-3 font-14 text-success'></i><span>Aile</span> @if(ViewBag.AileCount > 0){
                                            <span class="badge bg-success rounded-pill ms-auto">@ViewBag.AileCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Category/Eğitim" class="list-group-item @(ViewBag.ActiveFolder == "Eğitim" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-circle me-3 font-14 text-danger'></i><span>Eğitim</span> @if(ViewBag.EgitimCount > 0){
                                            <span class="badge bg-danger rounded-pill ms-auto">@ViewBag.EgitimCount</span>
                                                                                        }
                                        </a>
                                        <a href="/Message/Category/Sosyal" class="list-group-item @(ViewBag.ActiveFolder == "Sosyal" ? "active" : "") d-flex align-items-center">
                                            <i class='bx bxs-circle me-3 font-14 text-warning'></i><span>Sosyal</span> @if(ViewBag.SosyalCount > 0){
                                            <span class="badge bg-warning rounded-pill ms-auto">@ViewBag.SosyalCount</span>
                                                                                        }
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="email-header d-xl-flex align-items-center">
                            <div class="d-flex align-items-center">
                                <div class="email-toggle-btn"><i class='bx bx-menu'></i></div>
                                <div class="btn btn-white"><input class="form-check-input" type="checkbox"></div>
                                <button type="button" class="btn btn-white ms-2" onclick="location.reload();" title="Yenile"><i class='bx bx-refresh me-0'></i></button>
                                <button type="button" class="btn btn-white ms-2"><i class='bx bx-downvote me-0'></i></button>
                                <button type="button" class="btn btn-white ms-2"><i class='bx bx-trash me-0'></i></button>
                            </div>

                            <div class="flex-grow-1 mx-xl-3 my-2 my-xl-0">
                                <form method="get" action="/Message/Search" class="input-group" style="max-width: 500px;" onsubmit="return true;">
                                    <span class="input-group-text bg-transparent border-end-0"><i class="bx bx-search text-muted"></i></span>
                                    <input type="text" name="query" class="form-control border-start-0 bg-transparent" placeholder="Maillerde Ara..." value="@Context.Request.Query["query"]" />
                                    <button type="submit" class="d-none"></button>
                                </form>
                            </div>

                            <div class="ms-auto d-flex align-items-center">
                                @{
                                    int startItem = (ViewBag.CurrentPage - 1) * 13 + 1;
                                    int endItem = startItem + Model.Count - 1;
                                    if (ViewBag.TotalItems == 0) { startItem = 0; endItem = 0; }

                                    string baseUrl = "";
                                    if (ViewBag.ActiveFolder == "Search")
                                    {
                                        baseUrl = $"/Message/Search?query={Context.Request.Query["query"]}&page=";
                                    }
                                    else if (new[] { "İş", "Aile", "Eğitim", "Sosyal" }.Contains((string)ViewBag.ActiveFolder))
                                    {
                                        baseUrl = $"/Message/Category/{ViewBag.ActiveFolder}?page=";
                                    }
                                    else
                                    {
                                        baseUrl = $"/Message/{ViewBag.ActiveFolder}?page=";
                                    }
                                }

                                <button class="btn btn-sm btn-light fw-bold text-muted me-2">@startItem-@endItem of @ViewBag.TotalItems</button>

                                @if (ViewBag.CurrentPage > 1)
                                {
                                    <a href="@(baseUrl + (ViewBag.CurrentPage - 1))" class="btn btn-white px-2 border"><i class='bx bx-chevron-left me-0'></i></a>
                                }
                                else
                                {
                                    <button class="btn btn-white px-2 border" disabled><i class='bx bx-chevron-left me-0 text-muted'></i></button>
                                }

                                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                                {
                                    <a href="@(baseUrl + (ViewBag.CurrentPage + 1))" class="btn btn-white px-2 border ms-1"><i class='bx bx-chevron-right me-0'></i></a>
                                }
                                else
                                {
                                    <button class="btn btn-white px-2 border ms-1" disabled><i class='bx bx-chevron-right me-0 text-muted'></i></button>
                                }
                            </div>
                        </div>

                        <div class="email-content">
                            <div class="email-list">
                                @if (Model.Count > 0)
                                {
                                    foreach (var item in Model)
                                    {
                                        <div class="d-md-flex align-items-center email-message px-3 py-1 @(item.IsStatus ? "bg-white" : "bg-light")">
                                            <div class="d-flex align-items-center email-actions">
                                                <input class="form-check-input" type="checkbox" value="" />
                                                <a href="/Message/ToggleStar/@item.MessageId" style="text-decoration: none;">
                                                    <i class='bx @(item.IsStarred ? "bxs-star text-warning" : "bx-star text-muted") font-20 mx-2 email-star'></i>
                                                </a>
                                                <p class="mb-0 font-weight-bold" style="width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                                    @(ViewBag.ActiveFolder == "SendBox" ? item.ReceiverEmail : item.SenderEmail)
                                                </p>
                                            </div>

                                            <div class="ms-4 d-flex align-items-center flex-grow-1" style="overflow: hidden; cursor: pointer;" onclick="location.href='/Message/MessageDetail/@item.MessageId'">
                                                @if (!string.IsNullOrEmpty(item.Category))
                                                {
                                                    string badgeClass = "bg-primary";
                                                    if (item.Category == "Aile") badgeClass = "bg-success";
                                                    else if (item.Category == "Eğitim") badgeClass = "bg-danger";
                                                    else if (item.Category == "Sosyal") badgeClass = "bg-warning text-dark";

                                                    <span class="badge rounded-pill @badgeClass me-2">@item.Category</span>
                                                }
                                                <p class="mb-0 text-dark text-truncate">
                                                    <b>@item.Subject</b> <span class="text-muted mx-1">-</span>
                                                    <span class="text-muted">
                                                        @{
                                                            var cleanText = System.Text.RegularExpressions.Regex.Replace(item.MessageDetail ?? "", "<.*?>", string.Empty);
                                                            cleanText = System.Net.WebUtility.HtmlDecode(cleanText);
                                                        }
                                                        @(cleanText.Length > 80 ? cleanText.Substring(0, 80) + "..." : cleanText)
                                                    </span>
                                                </p>
                                            </div>

                                            <div class="ms-auto d-flex align-items-center">
                                                <a href="/Message/MoveToTrash/@item.MessageId" class="text-danger me-3" title="Çöpe At">
                                                    <i class="bx bx-trash font-20"></i>
                                                </a>
                                                <p class="mb-0 email-time">@item.SendDate.ToString("dd MMM HH:mm")</p>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="p-5 text-center text-muted mt-5">
                                        <i class="bx bx-envelope-open" style="font-size: 50px; color: #b0b0b0;"></i>
                                        <h5 class="mt-3">Bu klasör şu an boş.</h5>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="compose-mail-popup">
                            <div class="card shadow-lg border-0">
                                <div class="card-header text-white py-2 cursor-pointer" style="background-color: #673ab7;">
                                    <div class="d-flex align-items-center">
                                        <div class="compose-mail-title fw-bold">Yeni Mesaj</div>
                                        <div class="compose-mail-close ms-auto font-20"><i class="bx bx-x"></i></div>
                                    </div>
                                </div>
                                <div class="card-body p-0">
                                    <form method="post" asp-controller="Message" asp-action="CreateMessage">
                                        <input type="hidden" name="SenderEmail" value="@ViewBag.CurrentUser.Email" />
                                        <div class="email-form p-3">
                                            <div class="mb-3">
                                                <input type="email" name="ReceiverEmail" class="form-control border-0 border-bottom" placeholder="Kime (Email Adresi)" required />
                                            </div>
                                            <div class="mb-3">
                                                <input type="text" name="Subject" class="form-control border-0 border-bottom" placeholder="Konu" required />
                                            </div>
                                            <div class="mb-3">
                                                <select name="Category" class="form-select border-0 border-bottom text-muted" style="box-shadow: none; border-radius: 0;">
                                                    <option value="">Kategori Seçin (Opsiyonel)</option>
                                                    <option value="İş">İş</option>
                                                    <option value="Aile">Aile</option>
                                                    <option value="Eğitim">Eğitim</option>
                                                    <option value="Sosyal">Sosyal</option>
                                                </select>
                                            </div>
                                            <div class="mb-3 bg-white">
                                                <textarea id="summernote" name="MessageDetail" required></textarea>
                                            </div>
                                            <div class="mb-0 mt-3 d-flex align-items-center">
                                                <button type="submit" class="btn text-white rounded-pill px-4" style="background-color: #673ab7;">Gönder</button>

                                                <button type="submit" formaction="/Message/SaveDraft" class="btn btn-light rounded-pill px-4 ms-2 border fw-bold text-muted">Taslağa Kaydet</button>

                                                <div class="ms-auto text-muted font-20">
                                                    <i class="bx bx-trash cursor-pointer compose-mail-close"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/vertical/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/vertical/assets/js/jquery.min.js"></script>
    <script src="~/vertical/assets/plugins/simplebar/js/simplebar.min.js"></script>
    <script src="~/vertical/assets/plugins/metismenu/js/metisMenu.min.js"></script>
    <script src="~/vertical/assets/plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>

    <script>
        new PerfectScrollbar('.email-list');
        $(document).ready(function() {
            $('#summernote').summernote({
                placeholder: 'Mesajınızı buraya yazın...',
                tabsize: 2, height: 200,
                toolbar: [ ['style', ['style']], ['font', ['bold', 'italic', 'underline', 'clear']], ['color', ['color']], ['para', ['ul', 'ol', 'paragraph']], ['insert', ['link', 'picture']] ]
            });
        });
    </script>
    <script src="~/vertical/assets/js/app.js"></script>
</body>
</html>