@model Project2EmailNight.Dtos.UserEditDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Profilim - MailApp</title>
    <link rel="icon" href="~/vertical/assets/images/favicon-32x32.png" type="image/png" />
    <link href="~/vertical/assets/plugins/simplebar/css/simplebar.css" rel="stylesheet" />
    <link href="~/vertical/assets/plugins/perfect-scrollbar/css/perfect-scrollbar.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/vertical/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600&family=Roboto&display=swap" />
    <link rel="stylesheet" href="~/vertical/assets/css/icons.css" />
    <link rel="stylesheet" href="~/vertical/assets/css/app.css" />
    <style>
        .sidebar-wrapper {
            display: none !important;
        }

        .top-header {
            left: 0 !important;
            width: 100% !important;
            border-bottom: 1px solid #e4e4e4;
        }

        body {
            background-color: #f4f6f9 !important;
        }

        .page-wrapper {
            margin-left: 0 !important;
            margin-top: 60px !important;
            padding: 20px !important;
        }

        .widget-card {
            border-radius: 10px;
            border: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            transition: transform 0.2s;
        }

            .widget-card:hover {
                transform: translateY(-5px);
            }

        .widget-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .profile-card {
            border-radius: 10px;
            border: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }
    </style>
</head>

<body>
    <div class="wrapper">

        <header class="top-header">
            <nav class="navbar navbar-expand">
                <div class="left-topbar d-flex align-items-center">
                    <img src="~/vertical/assets/images/logo-icon.png" width="30" alt="" class="ms-3" />
                    <h4 class="logo-text ms-2 mb-0 text-dark">MailApp</h4>
                </div>

                <div class="flex-grow-1 d-flex justify-content-center align-items-center">
                    <a href="/Message/Inbox" class="btn btn-white border rounded-pill fw-bold shadow-sm px-4" style="color: #673ab7;">
                        <i class="bx bx-envelope me-1"></i> Gelen Kutusuna Dön
                    </a>
                </div>

                <div class="right-topbar ms-auto">
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown dropdown-user-profile">
                            <a class="nav-link dropdown-toggle dropdown-toggle-nocaret" href="javascript:;" data-bs-toggle="dropdown">
                                <div class="d-flex user-box align-items-center">
                                    <div class="user-info text-end me-2">
                                        <p class="user-name mb-0 text-dark font-weight-bold">@ViewBag.CurrentUser.Name @ViewBag.CurrentUser.SurName</p>
                                        <p class="designattion mb-0 text-muted">Çevrimiçi</p>
                                    </div>
                                    <img src="@(!string.IsNullOrEmpty(ViewBag.CurrentUser.ImageUrl) ? "/images/" + ViewBag.CurrentUser.ImageUrl : "/vertical/assets/images/avatars/avatar-1.png")" class="user-img" alt="user avatar">
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" href="/Profile/Index"><i class="bx bx-user"></i><span>Profilim</span></a>
                                <div class="dropdown-divider mb-0"></div>
                                <a class="dropdown-item" href="/Login/UserLogin"><i class="bx bx-power-off"></i><span>Çıkış Yap</span></a>
                            </div>
                        </li>
                    </ul>
                </div>
            </nav>
        </header>

        <div class="page-wrapper">
            <div class="page-content">

                <h5 class="mb-3 fw-bold text-dark"><i class="bx bx-bar-chart-alt-2 text-primary me-2"></i> Posta İstatistiklerim</h5>
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-5">

                    <div class="col">
                        <div class="card widget-card h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-light-primary text-primary"><i class='bx bxs-inbox'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.ReceivedCount</h4>
                                    <p class="mb-0 text-muted">Gelen Mesaj</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-light-info text-info"><i class='bx bxs-send'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.SentCount</h4>
                                    <p class="mb-0 text-muted">Gönderilen Mesaj</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-light-secondary text-secondary"><i class='bx bxs-file-blank'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.DraftCount</h4>
                                    <p class="mb-0 text-muted">Taslaklar</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-light-danger text-danger"><i class='bx bxs-trash'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.TrashCount</h4>
                                    <p class="mb-0 text-muted">Çöpteki Mesaj</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100" style="border-left: 4px solid #673ab7;">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon text-white" style="background-color: #673ab7;"><i class='bx bx-briefcase'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.WorkCount</h4>
                                    <p class="mb-0 text-muted">İş Kategorisi</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100" style="border-left: 4px solid #17a00e;">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-success text-white"><i class='bx bx-home-heart'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.FamilyCount</h4>
                                    <p class="mb-0 text-muted">Aile Kategorisi</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100" style="border-left: 4px solid #f41127;">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-danger text-white"><i class='bx bx-book-reader'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.EducationCount</h4>
                                    <p class="mb-0 text-muted">Eğitim Kategorisi</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card widget-card h-100" style="border-left: 4px solid #ffc107;">
                            <div class="card-body d-flex align-items-center">
                                <div class="widget-icon bg-warning text-dark"><i class='bx bx-group'></i></div>
                                <div class="ms-3">
                                    <h4 class="mb-0 fw-bold">@ViewBag.SocialCount</h4>
                                    <p class="mb-0 text-muted">Sosyal Kategorisi</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <div class="row">
                    <div class="col-12 col-lg-4 d-flex">
                        <div class="card profile-card w-100">
                            <div class="card-body text-center mt-4">
                                <img src="@(!string.IsNullOrEmpty(ViewBag.CurrentUser.ImageUrl) ? "/images/" + ViewBag.CurrentUser.ImageUrl : "/vertical/assets/images/avatars/avatar-1.png")" alt="Admin" class="rounded-circle p-1 bg-primary shadow" width="120" height="120">
                                <h4 class="mt-3 fw-bold">@ViewBag.CurrentUser.Name @ViewBag.CurrentUser.SurName</h4>
                                <p class="text-secondary mb-1">@ViewBag.CurrentUser.Email</p>

                                <hr class="my-4">
                                <div class="text-start">
                                    <h6 class="fw-bold text-dark"><i class="bx bx-info-circle me-1"></i> Hakkımda</h6>
                                    <p class="text-muted" style="font-size: 15px; line-height: 1.6;">
                                        @(string.IsNullOrEmpty(ViewBag.CurrentUser.About) ? "Henüz bir hakkımda yazısı eklenmemiş. Sağ taraftaki formdan kendinizden bahsedebilirsiniz." : ViewBag.CurrentUser.About)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-8 d-flex">
                        <div class="card profile-card w-100">
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-4 text-dark"><i class="bx bx-cog me-1"></i> Profil Bilgilerimi Güncelle</h5>

                                <form method="post" enctype="multipart/form-data">
                                    <div class="row mb-3">
                                        <div class="col-sm-6">
                                            <label class="form-label text-muted fw-bold">Adınız</label>
                                            <input type="text" asp-for="Name" class="form-control bg-light border-0" placeholder="Adınız" required />
                                        </div>
                                        <div class="col-sm-6 mt-3 mt-sm-0">
                                            <label class="form-label text-muted fw-bold">Soyadınız</label>
                                            <input type="text" asp-for="Surname" class="form-control bg-light border-0" placeholder="Soyadınız" required />
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-sm-6">
                                            <label class="form-label text-muted fw-bold">Email Adresi</label>
                                            <input type="email" asp-for="Email" class="form-control bg-light border-0" placeholder="Email Adresi" required />
                                        </div>
                                        <div class="col-sm-6 mt-3 mt-sm-0">
                                            <label class="form-label text-muted fw-bold">Şifreniz (Boş bırakırsanız değişmez)</label>
                                            <input type="password" asp-for="Password" class="form-control bg-light border-0" placeholder="Yeni Şifreniz (Opsiyonel)" />
                                        </div>
                                    </div>

                                    <div class="row mb-3">
                                        <div class="col-sm-12">
                                            <label class="form-label text-muted fw-bold">Hakkımda</label>
                                            <textarea asp-for="About" class="form-control bg-light border-0" rows="4" placeholder="Kendinizden bahsedin..."></textarea>
                                        </div>
                                    </div>

                                    <div class="row mb-4">
                                        <div class="col-sm-12">
                                            <label class="form-label text-muted fw-bold">Yeni Profil Fotoğrafı Yükle</label>
                                            <input type="file" asp-for="Image" class="form-control border bg-light" />
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-12 text-end">
                                            <button type="submit" class="btn btn-primary px-5 rounded-pill fw-bold shadow-sm" style="background-color: #673ab7; border-color: #673ab7;">Bilgileri Kaydet</button>
                                        </div>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="~/vertical/assets/js/bootstrap.bundle.min.js"></script>
    <script src="~/vertical/assets/js/jquery.min.js"></script>
    <script src="~/vertical/assets/plugins/simplebar/js/simplebar.min.js"></script>
    <script src="~/vertical/assets/plugins/metismenu/js/metisMenu.min.js"></script>
    <script src="~/vertical/assets/plugins/perfect-scrollbar/js/perfect-scrollbar.js"></script>
    <script src="~/vertical/assets/js/app.js"></script>
</body>
</html>